<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainPane" prefHeight="600.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1" fx:controller="logique.DashboardLogique" style="-fx-background-color: #FFF2E0;">
   <left>
      <VBox prefWidth="210.0" spacing="15.0" style="-fx-background-color: #898AC4;" BorderPane.alignment="CENTER">
         <children>
            <VBox>
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
               <children>
                  <Label alignment="CENTER" contentDisplay="CENTER" prefWidth="180.0" text="Menu Principal" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
               </children>
            </VBox>

            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#afficherLivres" style="-fx-background-color: #A2AADB; -fx-text-fill: #2C2C2C; -fx-background-radius: 6;" text="Gestion des Livres">
               <font>
                  <Font size="14.0" />
               </font>
            </Button>

            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#afficherAdherents" style="-fx-background-color: #A2AADB; -fx-text-fill: #2C2C2C; -fx-background-radius: 6;" text="Gestion des Adhérents">
               <font>
                  <Font size="14.0" />
               </font>
            </Button>

            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#afficherEmprunts" style="-fx-background-color: #A2AADB; -fx-text-fill: #2C2C2C; -fx-background-radius: 6;" text="Gestion des Emprunts">
               <font>
                  <Font size="14.0" />
               </font>
            </Button>

            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#afficherRetours" style="-fx-background-color: #A2AADB; -fx-text-fill: #2C2C2C; -fx-background-radius: 6;" text="Gestion des Retours">
               <font>
                  <Font size="14.0" />
               </font>
            </Button>

            <Region VBox.vgrow="ALWAYS" />

            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDeconnexion" style="-fx-background-color: #A2AADB; -fx-text-fill: #2C2C2C; -fx-background-radius: 6;" text="Se déconnecter">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Button>
         </children>
         <padding>
            <Insets bottom="20.0" left="15.0" right="15.0" top="30.0" />
         </padding>
      </VBox>
   </left>

   <center>
      <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="20.0" style="-fx-background-color: #FFF2E0;" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="lblBienvenue" text="Bienvenue !" textFill="#2C2C2C">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>

            <HBox alignment="CENTER" spacing="30.0">
               <children>
                  <VBox alignment="CENTER" style="-fx-background-color: #C0C9EE; -fx-background-radius: 12; -fx-padding: 20;">
                     <Label text="Livres en stock" textFill="#2C2C2C">
                        <font>
                           <Font name="System Bold" size="18.0" />
                        </font>
                     </Label>
                     <Label fx:id="lblStatLivres" text="0" textFill="#898AC4">
                        <font>
                           <Font name="System Bold" size="24.0" />
                        </font>
                     </Label>
                  </VBox>

                  <VBox alignment="CENTER" style="-fx-background-color: #C0C9EE; -fx-background-radius: 12; -fx-padding: 20;">
                     <Label text="Adhérents inscrits" textFill="#2C2C2C">
                        <font>
                           <Font name="System Bold" size="18.0" />
                        </font>
                     </Label>
                     <Label fx:id="lblStatAdherents" text="0" textFill="#898AC4">
                        <font>
                           <Font name="System Bold" size="24.0" />
                        </font>
                     </Label>
                  </VBox>

                  <VBox alignment="CENTER" style="-fx-background-color: #C0C9EE; -fx-background-radius: 12; -fx-padding: 20;">
                     <Label text="Emprunts en cours" textFill="#2C2C2C">
                        <font>
                           <Font name="System Bold" size="18.0" />
                        </font>
                     </Label>
                     <Label fx:id="lblStatEmprunts" text="0" textFill="#898AC4">
                        <font>
                           <Font name="System Bold" size="24.0" />
                        </font>
                     </Label>
                  </VBox>
               </children>
            </HBox>

            <Label text="Sélectionnez une option dans le menu de gauche pour commencer." textFill="#666666">
               <font>
                  <Font size="14.0" />
               </font>
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
         </children>
      </VBox>
   </center>
</BorderPane>
