<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="300.0" prefWidth="400.0" spacing="15.0" style="-fx-background-color: #FFF2E0;" xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1" fx:controller="logique.LoginLogique">
   <padding>
      <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
   </padding>
   <children>
      <Label text="Authentification" textFill="#2C2C2C">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
         <VBox.margin>
            <Insets bottom="10.0" />
         </VBox.margin>
      </Label>
      
      <TextField fx:id="txtUtilisateur" promptText="Nom d'utilisateur" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A2AADB;" />
      <PasswordField fx:id="txtMotDePasse" promptText="Mot de passe" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A2AADB;" />
      
      <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogin" style="-fx-background-color: #898AC4; -fx-text-fill: white; -fx-background-radius: 6;" text="Se connecter">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Button>
      
      <Label fx:id="lblMessage" textFill="RED" wrapText="true" />
   </children>
</VBox>
