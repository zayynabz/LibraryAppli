<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="500.0" prefWidth="850.0" spacing="20.0" xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1" fx:controller="logique.LivreLogique" style="-fx-background-color: #FFF2E0;">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <VBox spacing="10.0" HBox.hgrow="ALWAYS">
         <children>
            <Label text="Gestion des livres" textFill="#2C2C2C">
               <font><Font name="System Bold" size="20.0" /></font>
            </Label>

            <TextField fx:id="txtRecherche" promptText="Rechercher par titre, auteur ou categorie..." style="-fx-font-size: 14px; -fx-padding: 8px; -fx-background-color: white; -fx-border-color: #C0C9EE; -fx-border-radius: 6; -fx-background-radius: 6;" />

            <TableView fx:id="tableLivres" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #C0C9EE;">
              <columns>
                <TableColumn fx:id="colId" prefWidth="45.0" text="ID" />
                <TableColumn fx:id="colTitre" prefWidth="170.0" text="Titre" />
                <TableColumn fx:id="colAuteur" prefWidth="130.0" text="Auteur" />
                <TableColumn fx:id="colCategorie" prefWidth="110.0" text="Categorie" />
                <TableColumn fx:id="colAnnee" prefWidth="70.0" text="Annee" />
                <TableColumn fx:id="colQuantite" prefWidth="70.0" text="Stock" />
              </columns>
            </TableView>
         </children>
      </VBox>

      <VBox prefWidth="270.0" spacing="12.0" style="-fx-background-color: #C0C9EE; -fx-border-color: #A2AADB; -fx-border-radius: 8; -fx-background-radius: 8;">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
         <children>
            <Label prefHeight="22.0" prefWidth="123.0" text="Formulaire livre" textFill="#2C2C2C">
               <font><Font name="System Bold" size="16.0" /></font>
            </Label>
            <TextField fx:id="txtTitre" promptText="Titre" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A2AADB;" />
            <TextField fx:id="txtAuteur" promptText="Auteur" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A2AADB;" />
            <TextField fx:id="txtCategorie" promptText="Categorie" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A2AADB;" />
            <TextField fx:id="txtAnnee" promptText="Annee de publication" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A2AADB;" />
            <TextField fx:id="txtQuantite" promptText="Quantite" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A2AADB;" />

            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAjouter" style="-fx-background-color: #A2AADB; -fx-text-fill: #2C2C2C; -fx-background-radius: 6;" text="Ajouter" />
            <Button fx:id="btnModifier" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleModifier" style="-fx-background-color: #A2AADB; -fx-text-fill: #2C2C2C; -fx-background-radius: 6;" text="Modifier" />
            <Button fx:id="btnAnnuler" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAnnuler" style="-fx-background-color: #FFF2E0; -fx-text-fill: #2C2C2C; -fx-background-radius: 6;" text="Annuler la selection" />

            <Region VBox.vgrow="ALWAYS" />

            <Button fx:id="btnEmprunter" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleVersEmprunt" style="-fx-background-color: #898AC4; -fx-text-fill: white; -fx-background-radius: 6;" text="Aller vers emprunt" />
            <Button fx:id="btnSupprimer" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSupprimer" style="-fx-background-color: #D96C6C; -fx-text-fill: white; -fx-background-radius: 6;" text="Supprimer" />

            <Label fx:id="lblMessage" textFill="RED" wrapText="true" />
         </children>
      </VBox>
   </children>
</HBox>
