<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="500.0" prefWidth="850.0" spacing="20.0" xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1" fx:controller="logique.AdherentLogique" style="-fx-background-color: #FFF2E0;">
   <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
   <children>
      <VBox spacing="10.0" HBox.hgrow="ALWAYS">
         <children>
            <Label text="Gestion des adherents" textFill="#2C2C2C"><font><Font name="System Bold" size="20.0" /></font></Label>

            <TextField fx:id="txtRecherche" promptText="Rechercher par nom, prenom, email ou telephone..." style="-fx-font-size: 14px; -fx-padding: 8px; -fx-background-color: white; -fx-border-color: #C0C9EE; -fx-border-radius: 6; -fx-background-radius: 6;" />

            <TableView fx:id="tableAdherents" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #C0C9EE;">
              <columns>
                <TableColumn fx:id="colId" prefWidth="45.0" text="ID" />
                <TableColumn fx:id="colNom" prefWidth="100.0" text="Nom" />
                <TableColumn fx:id="colPrenom" prefWidth="100.0" text="Prenom" />
                <TableColumn fx:id="colEmail" prefWidth="165.0" text="Email" />
                <TableColumn fx:id="colTel" prefWidth="110.0" text="Telephone" />
                <TableColumn fx:id="colAdresse" prefWidth="140.0" text="Adresse" />
              </columns>
            </TableView>
         </children>
      </VBox>
      <VBox prefWidth="270.0" spacing="12.0" style="-fx-background-color: #C0C9EE; -fx-border-color: #A2AADB; -fx-border-radius: 8; -fx-background-radius: 8;">
         <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
         <children>
            <Label text="Formulaire adherent" textFill="#2C2C2C"><font><Font name="System Bold" size="16.0" /></font></Label>
            <TextField fx:id="txtNom" promptText="Nom" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A2AADB;" />
            <TextField fx:id="txtPrenom" promptText="Prenom" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A2AADB;" />
            <TextField fx:id="txtEmail" promptText="Email" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A2AADB;" />
            <TextField fx:id="txtTel" promptText="Telephone" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A2AADB;" />
            <TextField fx:id="txtAdresse" promptText="Adresse" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A2AADB;" />

            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAjouter" style="-fx-background-color: #A2AADB; -fx-text-fill: #2C2C2C; -fx-background-radius: 6;" text="Ajouter" />
            <Button fx:id="btnModifier" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleModifier" style="-fx-background-color: #A2AADB; -fx-text-fill: #2C2C2C; -fx-background-radius: 6;" text="Modifier" />
            <Button fx:id="btnAnnuler" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAnnuler" style="-fx-background-color: #FFF2E0; -fx-text-fill: #2C2C2C; -fx-background-radius: 6;" text="Annuler la selection" />

            <Region VBox.vgrow="ALWAYS" />

            <Button fx:id="btnSupprimer" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSupprimer" style="-fx-background-color: #D96C6C; -fx-text-fill: white; -fx-background-radius: 6;" text="Supprimer" />

            <Label fx:id="lblMessage" textFill="RED" wrapText="true" />
         </children>
      </VBox>
   </children>
</HBox>
