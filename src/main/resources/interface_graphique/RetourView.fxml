<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="500.0" prefWidth="850.0" spacing="20.0" xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1" fx:controller="logique.RetourLogique" style="-fx-background-color: #FFF2E0;">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>

   <children>
      <VBox spacing="10.0" HBox.hgrow="ALWAYS">
         <children>
            <Label text="Gestion des retours" textFill="#2C2C2C">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>

            <TableView fx:id="tableRetours" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #C0C9EE;">
               <columns>
                  <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                  <TableColumn fx:id="colLivre" prefWidth="180.0" text="Livre" />
                  <TableColumn fx:id="colAdherent" prefWidth="150.0" text="Adhérent" />
                  <TableColumn fx:id="colDateEmprunt" prefWidth="110.0" text="Date emprunt" />
                  <TableColumn fx:id="colDateRetour" prefWidth="120.0" text="Retour prévu" />
                  <TableColumn fx:id="colStatut" prefWidth="90.0" text="Statut" />
               </columns>
            </TableView>
         </children>
      </VBox>

      <VBox prefWidth="260.0" spacing="15.0" style="-fx-background-color: #C0C9EE; -fx-border-color: #A2AADB; -fx-border-radius: 8; -fx-background-radius: 8;">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>

         <children>
            <Label text="Retour livre" textFill="#2C2C2C">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Label>

            <Label text="Sélectionnez un emprunt dans le tableau puis cliquez sur le bouton pour enregistrer le retour." textFill="#2C2C2C" wrapText="true" />

            <Button fx:id="btnValiderRetour" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleRetour" style="-fx-background-color: #A2AADB; -fx-text-fill: #2C2C2C; -fx-background-radius: 6;" text="Valider le retour" />

            <Button fx:id="btnActualiser" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleActualiser" style="-fx-background-color: #FFF2E0; -fx-text-fill: #2C2C2C; -fx-background-radius: 6;" text="Actualiser" />

            <Region VBox.vgrow="ALWAYS" />

            <Label fx:id="lblMessage" textFill="RED" wrapText="true" />
         </children>
      </VBox>
   </children>
</HBox>
