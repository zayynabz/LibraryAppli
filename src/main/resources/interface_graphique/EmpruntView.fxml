<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="500.0" prefWidth="850.0" spacing="20.0" xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1" fx:controller="logique.EmpruntLogique" style="-fx-background-color: #FFF2E0;">
   <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
   <children>
      <VBox spacing="10.0" HBox.hgrow="ALWAYS">
         <children>
            <Label text="Gestion des Emprunts" textFill="#2C2C2C"><font><Font name="System Bold" size="20.0" /></font></Label>
            <TableView fx:id="tableEmprunts" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #C0C9EE;">
              <columns>
                <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />
                <TableColumn fx:id="colLivre" prefWidth="180.0" text="Livre" />
                <TableColumn fx:id="colAdherent" prefWidth="120.0" text="Adhérent" />
                <TableColumn fx:id="colDateEmprunt" prefWidth="100.0" text="Emprunté le" />
                <TableColumn fx:id="colDateRetour" prefWidth="100.0" text="Retour prévu" />
                <TableColumn fx:id="colStatut" prefWidth="80.0" text="Statut" />
              </columns>
            </TableView>
         </children>
      </VBox>
      <VBox prefWidth="250.0" spacing="15.0" style="-fx-background-color: #C0C9EE; -fx-border-color: #A2AADB; -fx-border-radius: 8; -fx-background-radius: 8;">
         <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
         <children>
            <Label text="Nouvel Emprunt" textFill="#2C2C2C"><font><Font name="System Bold" size="16.0" /></font></Label>
            
            <ComboBox fx:id="comboLivre" maxWidth="1.7976931348623157E308" promptText="Sélectionner le Livre" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A2AADB;" />
            <ComboBox fx:id="comboAdherent" maxWidth="1.7976931348623157E308" promptText="Sélectionner l'Adhérent" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A2AADB;" />
            
            <DatePicker fx:id="datePrevue" maxWidth="1.7976931348623157E308" promptText="Date de retour prévue" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #A2AADB;" />
            
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAjouter" style="-fx-background-color: #A2AADB; -fx-text-fill: #2C2C2C; -fx-background-radius: 6;" text="Enregistrer l'emprunt" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <Button fx:id="btnRetour" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleRetour" style="-fx-background-color: #898AC4; -fx-text-fill: white; -fx-background-radius: 6;" text="Marquer comme Rendu" />
            <Label fx:id="lblMessage" textFill="RED" wrapText="true" />
         </children>
      </VBox>
   </children>
</HBox>
